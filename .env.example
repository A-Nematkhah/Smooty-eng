# Copy this file to .env and fill in real values. .env is never committed.

# --- Telegram (required from Phase 3 onward; harmless if unset for now) ---
TELEGRAM_BOT_TOKEN=8786666538:AAFeXMrsaYn3BjHXVGhJbkISVs5PQeXJhjg

# --- Database ---
# Defaults to a local SQLite file at data/english_bot.db if left unset.
DATABASE_URL=sqlite:///./data/english_bot.db
SQL_ECHO=false

# --- Vocabulary data paths (defaults shown) ---
OXFORD3000_PATH=./data/oxford3000.json
IELTS_PATH=./data/ielts.json

# --- Scheduler / reminders ---
DEFAULT_REMINDER_TIME=09:00
SCHEDULER_TIMEZONE=UTC

# --- Logging ---
LOG_LEVEL=INFO
